# Скопируйте в .env в корне проекта (локальный запуск через uvicorn).
# На Vercel переменные не нужны — ключ вводится в браузере.

# Опционально для локального запуска: если не задан, ключ можно указать в UI (localStorage).
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# --- Опционально: виджет расхода и остатка в UI ---

# Admin API key с правом api.usage.read (Organization Costs API).
# Это НЕ тот же ключ, что OPENAI_API_KEY — создаётся отдельно в профиле OpenAI.
# OPENAI_ADMIN_API_KEY=sk-admin-...

# Альтернативное имя переменной (если уже используете его в других проектах):
# OPENAI_USAGE_API_KEY=sk-admin-...

# Стартовый баланс в USD (если не задаёте через UI «Настройки → Баланс OpenAI»).
# Удобнее сохранить баланс в UI — при каждом «Сохранить» фиксируется новая точка отсчёта.
# OPENAI_BILLING_CREDIT_USD=50.00

# Расширенная настройка биллинга через env (обычно не нужна):
# OPENAI_BILLING_CREDIT_SET_AT=1735689600
# OPENAI_BILLING_BASELINE_SPENT_USD=12.34
# OPENAI_BILLING_ANCHOR_DAY_UNIX=1735689600
